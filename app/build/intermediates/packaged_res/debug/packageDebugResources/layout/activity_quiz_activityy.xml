<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".QuizActivity">

    <TextView
        android:id="@+id/idFeedback"
        android:layout_width="343dp"
        android:layout_height="106dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="55dp"
        android:padding="10dp"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/btnNext"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnFalse" />

    <Button
        android:id="@+id/btnNext"
        android:layout_width="424dp"
        android:layout_height="61dp"
        android:layout_marginBottom="27dp"
        android:text="NEXT"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idFeedback" />

    <Button
        android:id="@+id/btnTrue"
        android:layout_width="426dp"
        android:layout_height="65dp"
        android:layout_marginBottom="23dp"
        android:text="Hack (True)"
        app:layout_constraintBottom_toTopOf="@+id/btnFalse"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idQuestion" />

    <TextView
        android:id="@+id/idQuestion"
        android:layout_width="308dp"
        android:layout_height="135dp"
        android:layout_marginStart="64dp"
        android:layout_marginTop="61dp"
        android:layout_marginBottom="60dp"
        android:text="Question Here"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/btnTrue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnFalse"
        android:layout_width="429dp"
        android:layout_height="71dp"
        android:layout_marginBottom="75dp"
        android:text="Myth (False)"
        app:layout_constraintBottom_toTopOf="@+id/idFeedback"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnTrue" />

    <LinearLayout
        android:layout_width="425dp"
        android:layout_height="726dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.766"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"></LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>